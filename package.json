{
  "name": "cartpick",
  "version": "0.1.0",
  "private": true,
  "description": "마트/편의점 상품 리뷰 플랫폼",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:migrate": "pnpm --filter @cartpick/api prisma:migrate",
    "db:seed": "pnpm --filter @cartpick/api prisma:seed",
    "db:studio": "pnpm --filter @cartpick/api prisma:studio"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
